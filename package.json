{
  "name": "divya-drishti-agent",
  "version": "1.0.0",
  "description": "Policy-driven AI code auditor and remediation CLI for security, logic, performance, and UI checks.",
  "main": "./index.js",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./pipeline": "./pipeline.js",
    "./core/*": "./core/*.js"
  },
  "bin": {
    "divya": "./cli.js"
  },
  "files": [
    "cli.js",
    "index.js",
    "pipeline.js",
    "agent.yaml",
    "core/",
    "skills/",
    "tools/",
    "utils/",
    "rules.json",
    "rules/"
  ],
  "scripts": {
    "start": "node index.js",
    "scan": "node cli.js scan .",
    "create": "node cli.js create auth --feature \"login system\" --safe --no-git",
    "fix": "node cli.js fix . --from-memory --dry-run",
    "report": "node cli.js report",
    "summary": "node cli.js summary",
    "clean": "node cli.js clean",
    "prepublishOnly": "npm run scan"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai-agent",
    "code-audit",
    "security",
    "devops",
    "cli",
    "autofix"
  ],
  "author": "Divya Drishti Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^17.4.1",
    "fs-extra": "^11.3.4",
    "glob": "^10.5.0",
    "ignore": "^7.0.5",
    "inquirer": "^13.4.1",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.0",
    "natural": "^8.1.1",
    "openai": "^6.34.0",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "puppeteer": "^24.40.0",
    "winston": "^3.19.0"
  }
}
